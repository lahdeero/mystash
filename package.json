{
  "name": "mystash",
  "private": true,
  "scripts": {
    "init": "pnpm install",
    "dev": "pnpm --filter frontend dev & pnpm --filter backend dev",
    "reset:deps": "pnpm run remove:deps && pnpm run init",
    "remove:deps": "find . -type d -name 'node_modules' -prune -exec rm -rf '{}' +"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.8.1",
    "typescript": "^4.9.5",
    "vitest": "^3.1.4"
  }
}
